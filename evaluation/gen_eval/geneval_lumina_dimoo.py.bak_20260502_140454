def _compute_rope_wavelengths_from_theta(head_dim, rope_theta):
    return [2.0 * math.pi * (rope_theta ** (i / head_dim)) for i in range(0, head_dim, 2)]


def _clear_rope_cache(model):
    for block in model.model.transformer.blocks:
        if hasattr(block, "rotary_emb"):
            cache = block.rotary_emb._RotaryEmbedding__cache
            cache.pop("rope_pos_sin", None)
            cache.pop("rope_pos_cos", None)


def _configure_rope_mode(model, rope_encoding_mode):
    head_dim = model.config.d_model // model.config.n_heads
    if rope_encoding_mode == "custom":
        wavelengths = list(DEFAULT_ROPE_WAVELENGTHS_1024)
        for c in (model.config, model.model.config):
            c.rope_wavelengths = wavelengths
        print("[RoPE] mode=custom (explicit wavelength table)")
    else:
        wavelengths = _compute_rope_wavelengths_from_theta(head_dim, model.config.rope_theta)
        for c in (model.config, model.model.config):
            c.rope_wavelengths = None
        print(f"[RoPE] mode=original (computed from rope_theta={model.config.rope_theta})")

    _clear_rope_cache(model)
    print(f"[RoPE] head_dim={head_dim}, num_frequency_pairs={head_dim // 2}")
    print(f"[RoPE] first 8 wavelengths: {[round(float(x), 2) for x in wavelengths[:8]]}")


def convert_torch_to_int(data):
    if isinstance(data, torch.Tensor):
        return int(data.item())
    if isinstance(data, list):
        return [convert_torch_to_int(item) for item in data]
    if isinstance(data, dict):
        return {key: convert_torch_to_int(value) for key, value in data.items()}
    return data


def default_dump(obj):
    if isinstance(obj, (np.integer, np.floating, np.bool_)):
        return obj.item()
    if isinstance(obj, np.ndarray):
        return obj.tolist()
    return obj


def _format_tag_value(value):
    if isinstance(value, bool):
        return "1" if value else "0"
    if isinstance(value, int):
        return str(value)
    if isinstance(value, float):
        text = f"{value:.10f}".rstrip("0").rstrip(".")
        if text == "-0":
            text = "0"
        return text.replace("-", "m").replace(".", "p")
    text = str(value).strip().replace(" ", "_")
    safe_chars = []
    for ch in text:
        if ch.isalnum() or ch in ("-", "_"):
            safe_chars.append(ch)
        elif ch == ".":
            safe_chars.append("p")
    return "".join(safe_chars) or "na"


def _build_hparam_prefix(args):
    parts = [
        ("timesteps", args.timesteps),
        ("high_conf_threshold", args.high_conf_threshold),
        ("high_conf_start_step", args.high_conf_start_step),
        ("neighborhood_size", args.neighborhood_size),
        ("neighborhood_mean_threshold", args.neighborhood_mean_threshold),
        ("decoded_neighbor_rule", int(bool(args.decoded_neighbor_rule))),
        ("decoded_neighbor_start_ratio", args.decoded_neighbor_start_ratio),
        ("decoded_neighbor_min_count", args.decoded_neighbor_min_count),
    ]
    return "_".join(f"{name}{_format_tag_value(value)}" for name, value in parts)


def _md_escape(value):
    text = "" if value is None else str(value)
    return text.replace("|", "\\|").replace("\n", " ").replace("\r", " ")


def _write_executed_steps_report(output_dir, run_folder, rows, total_generation_time_seconds):
    report_path = os.path.join(output_dir, "executed_steps_report.md")
    ok_rows = [row for row in rows if row.get("status") == "ok" and row.get("executed_steps") is not None]
    executed_vals = [int(row["executed_steps"]) for row in ok_rows]
    elapsed_rows = [row for row in rows if row.get("elapsed_seconds") is not None]
    elapsed_vals = [float(row["elapsed_seconds"]) for row in elapsed_rows]
    ok_elapsed_vals = [float(row["elapsed_seconds"]) for row in ok_rows if row.get("elapsed_seconds") is not None]
    summary = {
        "total_images": len(rows),
        "successful_images": len(ok_rows),
        "failed_images": len(rows) - len(ok_rows),
        "avg_executed_steps": (sum(executed_vals) / len(executed_vals)) if executed_vals else None,
        "min_executed_steps": min(executed_vals) if executed_vals else None,
        "max_executed_steps": max(executed_vals) if executed_vals else None,
        "total_generation_time_seconds": float(total_generation_time_seconds),
        "sum_per_image_elapsed_seconds": sum(elapsed_vals) if elapsed_vals else None,
        "avg_elapsed_seconds_per_image": (sum(elapsed_vals) / len(elapsed_vals)) if elapsed_vals else None,
        "avg_elapsed_seconds_per_successful_image": (sum(ok_elapsed_vals) / len(ok_elapsed_vals)) if ok_elapsed_vals else None,
        "min_elapsed_seconds": min(elapsed_vals) if elapsed_vals else None,
        "max_elapsed_seconds": max(elapsed_vals) if elapsed_vals else None,
    }

    with open(report_path, "w", encoding="utf-8") as f:
        f.write("# Executed Steps Report\n\n")
        f.write(f"- run_folder: `{run_folder}`\n")
        f.write(f"- total_images: {summary['total_images']}\n")
        f.write(f"- successful_images: {summary['successful_images']}\n")
        f.write(f"- failed_images: {summary['failed_images']}\n")
        f.write(f"- total_generation_time_seconds: {summary['total_generation_time_seconds']:.4f}\n")
        if summary["sum_per_image_elapsed_seconds"] is None:
            f.write("- sum_per_image_elapsed_seconds: N/A\n")
            f.write("- avg_elapsed_seconds_per_image: N/A\n")
            f.write("- avg_elapsed_seconds_per_successful_image: N/A\n")
            f.write("- min_elapsed_seconds: N/A\n")
            f.write("- max_elapsed_seconds: N/A\n")
        else:
            f.write(f"- sum_per_image_elapsed_seconds: {summary['sum_per_image_elapsed_seconds']:.4f}\n")
            f.write(f"- avg_elapsed_seconds_per_image: {summary['avg_elapsed_seconds_per_image']:.4f}\n")
            if summary["avg_elapsed_seconds_per_successful_image"] is None:
                f.write("- avg_elapsed_seconds_per_successful_image: N/A\n")
            else:
                f.write(f"- avg_elapsed_seconds_per_successful_image: {summary['avg_elapsed_seconds_per_successful_image']:.4f}\n")
            f.write(f"- min_elapsed_seconds: {summary['min_elapsed_seconds']:.4f}\n")
            f.write(f"- max_elapsed_seconds: {summary['max_elapsed_seconds']:.4f}\n")
        if summary["avg_executed_steps"] is None:
            f.write("- avg_executed_steps: N/A\n")
            f.write("- min_executed_steps: N/A\n")
            f.write("- max_executed_steps: N/A\n")
        else:
            f.write(f"- avg_executed_steps: {summary['avg_executed_steps']:.4f}\n")
            f.write(f"- min_executed_steps: {summary['min_executed_steps']}\n")
            f.write(f"- max_executed_steps: {summary['max_executed_steps']}\n")

        f.write("\n## Per-Image Records\n\n")
        f.write("| prompt_idx | sample_idx | seed | status | elapsed_seconds | executed_steps | early_exit_step | total_timesteps | decoded_neighbor_activation_step | decoded_neighbor_total_decodes | sample_path | prompt_preview | error |\n")
        f.write("|---|---:|---:|---|---:|---:|---:|---:|---:|---:|---|---|---|\n")
        for row in rows:
            f.write(
                "| "
                + " | ".join(
                    [
                        _md_escape(row.get("prompt_idx")),
                        _md_escape(row.get("sample_idx")),
                        _md_escape(row.get("seed")),
                        _md_escape(row.get("status")),
                        _md_escape(row.get("elapsed_seconds")),
                        _md_escape(row.get("executed_steps")),
                        _md_escape(row.get("early_exit_step")),
