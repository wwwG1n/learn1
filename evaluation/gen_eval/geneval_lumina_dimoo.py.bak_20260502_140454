                        _md_escape(row.get("prompt_preview")),
                        _md_escape(row.get("error")),
                    ]
                )
                + " |\n"
            )

    return report_path, summary


def generate_single_image(
    model,
    tokenizer,
    vqvae,
    prompt_text,
    height,
    width,
    timesteps,
    cfg_scale,
    temperature,
    seed,
    use_cache,
    cache_ratio,
    warmup_ratio,
    refresh_interval,
    device,
    high_conf_threshold=0.9,
    high_conf_start_step=10,
    neighborhood_size=3,
    neighborhood_mean_threshold=0.2,
    decoded_neighbor_rule=False,
    decoded_neighbor_start_ratio=(1.0 / 3.0),
    decoded_neighbor_min_count=2,
    branch_interval=0,
    branch_start=5,
    return_tracking=False,
    return_stats=False,
):
    MASK = SPECIAL_TOKENS["mask_token"]
    NEW_LINE = SPECIAL_TOKENS["newline_token"]
    BOA = SPECIAL_TOKENS["answer_start"]
    EOA = SPECIAL_TOKENS["answer_end"]
    BOI = SPECIAL_TOKENS["boi"]
    EOI = SPECIAL_TOKENS["eoi"]

    if seed > 0:
        setup_seed(seed)

    seq_len, newline_every, token_grid_height, token_grid_width = calculate_vq_params(height, width)
    templates = create_prompt_templates()
    input_prompt, uncon_prompt = generate_text_to_image_prompt(prompt_text, templates)
    con_prompt_token = tokenizer(input_prompt)["input_ids"]
    uncon_prompt_token = tokenizer(uncon_prompt)["input_ids"]
    img_mask_token = add_break_line(
        [MASK] * seq_len,
        token_grid_height,
        token_grid_width,
        new_number=NEW_LINE,
    )
    img_pred_token = [BOA] + [BOI] + img_mask_token + [EOI] + [EOA]
    prompt_ids = torch.tensor(con_prompt_token + img_pred_token, device=device).unsqueeze(0)
    uncon_ids = torch.tensor(uncon_prompt_token, device=device).unsqueeze(0)
    code_start = len(con_prompt_token) + 2

    gen_out = generate_image(
        model,
        prompt_ids,
        seq_len=seq_len,
        newline_every=newline_every,
        timesteps=timesteps,
        temperature=temperature,
        cfg_scale=cfg_scale,
        uncon_ids=uncon_ids,
        code_start=code_start,
        use_cache=use_cache,
        cache_ratio=cache_ratio,
        refresh_interval=refresh_interval,
        warmup_ratio=warmup_ratio,
        high_conf_threshold=high_conf_threshold,
        high_conf_start_step=high_conf_start_step,
        neighborhood_size=neighborhood_size,
        neighborhood_mean_threshold=neighborhood_mean_threshold,
        decoded_neighbor_rule=decoded_neighbor_rule,
        decoded_neighbor_start_ratio=decoded_neighbor_start_ratio,
        decoded_neighbor_min_count=decoded_neighbor_min_count,
        return_tracking=return_tracking,
        return_stats=return_stats,
        branch_interval=branch_interval,
        branch_start=branch_start,
    )

    tracking = None
    branch_snapshots = []
    if return_tracking or return_stats:
        vq_tokens, tracking = gen_out
        branch_snapshots = tracking.get("branch_snapshots", [])
    elif branch_interval > 0:
        vq_tokens, branch_snapshots = gen_out
    else:
        vq_tokens = gen_out

    temp_path = "/tmp/temp_image.png"
    final_img = decode_vq_to_image(
        vq_tokens,
        temp_path,
        vae_ckpt=None,
        image_height=height,
        image_width=width,
        vqvae=vqvae,
    )
    if return_tracking or return_stats or branch_interval > 0:
        return final_img, tracking, branch_snapshots, code_start, seq_len
    return final_img


def main(args):
    print("Lumina-DiMOO GenEval generation")
    print(f"checkpoint={args.checkpoint}")
    print(f"metadata_file={args.metadata_file}")
    print(f"rewrite={args.rewrite}, rewrite_cache_file={args.rewrite_cache_file}")
    user_prefix = (args.output_dir_prefix or "").strip()
    hparam_prefix = _build_hparam_prefix(args)
    prefix = f"{user_prefix}_{hparam_prefix}" if user_prefix else hparam_prefix

    setup_seed(args.seed)

    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    if prefix:
        run_folder = f"{prefix}_lumina_dimoo_geneval_{timestamp}"
    else:
        run_folder = f"lumina_dimoo_geneval_{timestamp}"
    output_dir = os.path.join(args.output_root, run_folder)
    os.makedirs(output_dir, exist_ok=True)
    print(f"run_dir={os.path.abspath(output_dir)}")
    print(f"hparam_prefix={hparam_prefix}")
    if user_prefix:
        print(f"user_prefix={user_prefix}")
    print(f"resolved_output_prefix={prefix}")

    device = "cuda" if torch.cuda.is_available() else "cpu"
    print(f"device={device}")

    rewrite_cache_path = os.path.abspath(args.rewrite_cache_file)
    prompt_rewrite_cache: dict = {}
    rewriter = None
    if args.rewrite:
        if os.path.isfile(rewrite_cache_path):
            with open(rewrite_cache_path, encoding="utf-8") as f:
                prompt_rewrite_cache = json.load(f)
        else:
            print(f"[rewrite] no cache file yet, will create on API fills: {rewrite_cache_path}")
        from prompt_rewriter import PromptRewriter

        rewriter = PromptRewriter(system="", few_shot_history=[])
    cache_modified = False

    print("Loading tokenizer / model / VQVAE ...")
    tokenizer = AutoTokenizer.from_pretrained(args.checkpoint, trust_remote_code=True)
    model = LLaDAForMultiModalGeneration.from_pretrained(
        args.checkpoint,
        torch_dtype=torch.bfloat16,
        device_map="auto",
    )
    model.eval()
    _configure_rope_mode(model, args.rope_encoding_mode)
    vqvae = VQModel.from_pretrained(args.checkpoint, subfolder="vqvae").to(device)
    vqvae.eval()
    print("Model ready.")

    with open(args.metadata_file, encoding="utf-8") as fp:
        metadatas = [json.loads(line) for line in fp]
    print(f"num_prompts={len(metadatas)}")

    total_time = 0
    executed_step_rows = []
    for index, metadata in enumerate(tqdm(metadatas, desc="generate")):
        sample_output_dir = os.path.join(output_dir, f"{index:05d}")
        os.makedirs(sample_output_dir, exist_ok=True)
        samples_dir = os.path.join(sample_output_dir, "samples")
        os.makedirs(samples_dir, exist_ok=True)

        original_prompt = metadata["prompt"]
        gen_prompt = original_prompt
        if args.rewrite and rewriter is not None:
            if original_prompt in prompt_rewrite_cache:
                gen_prompt = prompt_rewrite_cache[original_prompt]
            else:
                gen_prompt = rewriter.rewrite(original_prompt)
                prompt_rewrite_cache[original_prompt] = gen_prompt
                cache_modified = True
            if gen_prompt != original_prompt:
                print(f"\n[{index}] rewrite: {original_prompt[:80]!r} -> {gen_prompt[:80]!r}")

        print(f"\n[{index + 1}/{len(metadatas)}] gen_prompt[:80]={gen_prompt[:80]!r}...")

        metadata_converted = convert_torch_to_int(metadata)
        with open(os.path.join(sample_output_dir, "metadata.jsonl"), "w", encoding="utf-8") as fp:
            json.dump(metadata_converted, fp, indent=4, default=default_dump)

        sample_images = []
        t0 = time.time()
        for sample_idx in range(args.n_samples):
            sample_seed = args.seed + index * args.n_samples + sample_idx
            sample_image_path = os.path.join(samples_dir, f"{sample_idx:04d}.png")
            sample_t0 = time.time()
            try:
                want_trace = bool(args.save_heatmaps)
                want_branches = int(args.branch_interval) > 0
                want_stats = True
                out = generate_single_image(
                    model=model,
                    tokenizer=tokenizer,
                    vqvae=vqvae,
                    prompt_text=gen_prompt,
                    height=args.height,
                    width=args.width,
                    timesteps=args.timesteps,
                    cfg_scale=args.cfg_scale,
                    temperature=args.temperature,
                    seed=sample_seed,
                    use_cache=args.use_cache,
                    cache_ratio=args.cache_ratio,
                    warmup_ratio=args.warmup_ratio,
                    refresh_interval=args.refresh_interval,
                    device=device,
                    high_conf_threshold=args.high_conf_threshold,
                    high_conf_start_step=args.high_conf_start_step,
                    neighborhood_size=args.neighborhood_size,
                    neighborhood_mean_threshold=args.neighborhood_mean_threshold,
                    decoded_neighbor_rule=args.decoded_neighbor_rule,
                    decoded_neighbor_start_ratio=args.decoded_neighbor_start_ratio,
                    decoded_neighbor_min_count=args.decoded_neighbor_min_count,
                    branch_interval=args.branch_interval,
                    branch_start=args.branch_start,
                    return_tracking=want_trace,
                    return_stats=want_stats,
                )
                if want_trace or want_stats or want_branches:
                    img, tracking, branch_snaps, code_start, seq_len = out
                else:
                    img = out
                    tracking, branch_snaps, code_start, seq_len = None, [], None, None

                img.save(sample_image_path)
                sample_images.append(img)

                if branch_snaps or want_trace:
                    snap_dir = os.path.join(samples_dir, f"{sample_idx:04d}_snapshots")
                    os.makedirs(snap_dir, exist_ok=True)
                    if branch_snaps:
                        newline_id = SPECIAL_TOKENS["newline_token"]
                        for step_1b, x_snap in branch_snaps:
                            vq_ids_snap = x_snap[0, code_start:-2]
                            vq_ids_snap = vq_ids_snap[vq_ids_snap != newline_id].view(1, seq_len)
                            bpath = os.path.join(snap_dir, f"branch_step_{step_1b:02d}.png")
                            bimg = decode_vq_to_image(
                                vq_ids_snap, bpath,
                                vae_ckpt=None,
                                image_height=args.height,
                                image_width=args.width,
                                vqvae=vqvae,
                            )
                            bimg.save(bpath)
                    if want_trace and tracking is not None:
                        try:
                            from tools.plot_token_trace_heatmaps import _plot_step_grid, _plot_decode_step_map
                            T_ = tracking["timesteps"]
                            H_ = tracking["grid_height"]
                            W_ = tracking["grid_width"]
                            conf_arr = np.array(tracking["conf_matrix"], dtype=np.float32).reshape(H_ * W_, T_)
                            conf_arr = conf_arr.reshape(H_, W_, T_).transpose(2, 0, 1)
                            ds_arr = np.array(tracking["decode_step"], dtype=np.int32).reshape(H_, W_)
                            _plot_step_grid(
                                conf_arr,
                                os.path.join(snap_dir, "confidence_heatmaps.png"),
                                title=f"sample{sample_idx:04d} | per-step conf ({H_}x{W_}), T={T_}",
                            )
                            _plot_decode_step_map(
                                ds_arr, T_,
                                os.path.join(snap_dir, "decode_step_map.png"),
                                title=f"sample{sample_idx:04d} | decode step map ({H_}x{W_})",
                            )
                        except Exception as e:
                            print(f"  [Heatmap] skipped: {e}")

                executed_steps = None
                early_exit_step = None
                total_timesteps = args.timesteps
                decoded_neighbor_activation_step = None
                decoded_neighbor_total_decodes = None
                if tracking is not None:
                    total_timesteps = int(tracking.get("total_timesteps", args.timesteps))
                    early_exit_step = tracking.get("early_exit_step")
                    executed_steps = int(tracking.get("executed_steps", early_exit_step or total_timesteps))
                    decoded_neighbor_activation_step = tracking.get("decoded_neighbor_activation_step")
                    decoded_neighbor_total_decodes = tracking.get("decoded_neighbor_total_decodes")
                sample_elapsed = time.time() - sample_t0

                executed_step_rows.append(
                    {
                        "prompt_idx": index + 1,
                        "sample_idx": sample_idx + 1,
                        "seed": sample_seed,
                        "status": "ok",
                        "elapsed_seconds": round(sample_elapsed, 4),
                        "executed_steps": executed_steps,
                        "early_exit_step": early_exit_step,
                        "total_timesteps": total_timesteps,
                        "decoded_neighbor_activation_step": decoded_neighbor_activation_step,
                        "decoded_neighbor_total_decodes": decoded_neighbor_total_decodes,
                        "sample_path": sample_image_path,
                        "prompt_preview": gen_prompt[:120],
                        "error": "",
                    }
                )
                print(f"  ok sample {sample_idx + 1}/{args.n_samples} ({sample_elapsed:.2f}s)")
            except Exception as e:
                sample_elapsed = time.time() - sample_t0
                print(f"  fail sample {sample_idx + 1}: {e}")
                blank = Image.new("RGB", (args.width, args.height), color="gray")
                blank.save(sample_image_path)
                sample_images.append(blank)
                executed_step_rows.append(
                    {
                        "prompt_idx": index + 1,
                        "sample_idx": sample_idx + 1,
                        "seed": sample_seed,
                        "status": "fail",
                        "elapsed_seconds": round(sample_elapsed, 4),
                        "executed_steps": None,
                        "early_exit_step": None,
                        "total_timesteps": args.timesteps,
                        "decoded_neighbor_activation_step": None,
                        "decoded_neighbor_total_decodes": None,
                        "sample_path": sample_image_path,
                        "prompt_preview": gen_prompt[:120],
                        "error": str(e),
                    }
                )

        if sample_images:
            grid_cols = int(np.ceil(np.sqrt(args.n_samples)))
            grid_rows = int(np.ceil(args.n_samples / grid_cols))
            grid_img = Image.new("RGB", (args.width * grid_cols, args.height * grid_rows), color="white")
            for idx, img in enumerate(sample_images):
                row, col = idx // grid_cols, idx % grid_cols
                grid_img.paste(img, (col * args.width, row * args.height))
            grid_img.save(os.path.join(sample_output_dir, "grid.png"))

        elapsed = time.time() - t0
        total_time += elapsed
        print(f"  elapsed {elapsed:.2f}s ({elapsed / args.n_samples:.2f}s / img)")

    if args.rewrite and cache_modified:
        os.makedirs(os.path.dirname(rewrite_cache_path) or ".", exist_ok=True)
        with open(rewrite_cache_path, "w", encoding="utf-8") as f:
            json.dump(prompt_rewrite_cache, f, indent=2, ensure_ascii=False)
        print(f"rewrite cache saved -> {rewrite_cache_path}")

    executed_steps_report_path, executed_steps_summary = _write_executed_steps_report(
        output_dir,
        run_folder,
        executed_step_rows,
        total_time,
    )
    avg_msg = executed_steps_summary["avg_executed_steps"]
    avg_str = "N/A" if avg_msg is None else f"{avg_msg:.4f}"
    print(f"[ExecutedSteps] report -> {executed_steps_report_path}")
    print(
        "[ExecutedSteps] "
        f"successful={executed_steps_summary['successful_images']}/{executed_steps_summary['total_images']} "
        f"avg={avg_str} "
        f"min={executed_steps_summary['min_executed_steps']} "
        f"max={executed_steps_summary['max_executed_steps']}"
    )

    params = {
        "checkpoint": args.checkpoint,
        "metadata_file": args.metadata_file,
        "output_root": args.output_root,
        "output_dir_prefix": user_prefix,
        "hparam_prefix": hparam_prefix,
        "resolved_output_prefix": prefix,
        "run_folder": run_folder,
        "rewrite": args.rewrite,
        "rewrite_cache_file": rewrite_cache_path,
        "n_samples": args.n_samples,
        "height": args.height,
        "width": args.width,
        "timesteps": args.timesteps,
        "cfg_scale": args.cfg_scale,
        "temperature": args.temperature,
        "seed": args.seed,
        "use_cache": args.use_cache,
        "cache_ratio": args.cache_ratio,
        "warmup_ratio": args.warmup_ratio,
        "refresh_interval": args.refresh_interval,
        "high_conf_threshold": args.high_conf_threshold,
        "high_conf_start_step": args.high_conf_start_step,
        "neighborhood_size": args.neighborhood_size,
        "neighborhood_mean_threshold": args.neighborhood_mean_threshold,
        "decoded_neighbor_rule": args.decoded_neighbor_rule,
        "decoded_neighbor_start_ratio": args.decoded_neighbor_start_ratio,
        "decoded_neighbor_min_count": args.decoded_neighbor_min_count,
        "rope_encoding_mode": args.rope_encoding_mode,
        "total_samples": len(metadatas),
        "total_images": len(metadatas) * args.n_samples,
        "total_time": total_time,
        "avg_time_per_image": total_time / max(1, len(metadatas) * args.n_samples),
        "executed_steps_report_path": executed_steps_report_path,
        "executed_steps_summary": executed_steps_summary,
        "timestamp": timestamp,
    }
    with open(os.path.join(output_dir, "generation_params.json"), "w", encoding="utf-8") as f:
        json.dump(params, f, indent=4)
    print(f"done -> {output_dir}")
    print("OUTPUT_DIR_FINAL=" + os.path.abspath(output_dir), flush=True)


if __name__ == "__main__":
    main(get_args_parser().parse_args())
